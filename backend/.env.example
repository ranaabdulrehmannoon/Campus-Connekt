# DATABASE CONFIGURATION - MySQL
# Get these values from PlanetScale dashboard
DB_HOST=[YOUR_PLANETSCALE_HOST]
DB_USER=[YOUR_PLANETSCALE_USERNAME]
DB_PASSWORD=[YOUR_PLANETSCALE_PASSWORD]
DB_NAME=campus_connekt

# Get connection string from MongoDB Atlas cluster
MONGODB_URI=mongodb+srv://[USERNAME]:[PASSWORD]@[CLUSTER].mongodb.net/?appName=CampusConnekt

# JWT CONFIGURATION
# Generate new secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=[GENERATE_NEW_32_CHARACTER_SECRET]
JWT_EXPIRE=7d

# SERVER CONFIGURATION
PORT=5000
FRONTEND_URL=https://[YOUR_VERCEL_FRONTEND_URL]

# ADMIN ACCOUNT - Change after first login
ADMIN_EMAIL=[YOUR_ADMIN_EMAIL]
ADMIN_PASSWORD=[CREATE_STRONG_PASSWORD]

# EMAIL SERVICE CONFIGURATION
# Option 1: Gmail (use app password from account settings)
# Option 2: SendGrid/Resend (use API key)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=[YOUR_EMAIL_OR_API_KEY]
EMAIL_PASS=[YOUR_APP_PASSWORD_OR_API_KEY]
EMAIL_FROM=[YOUR_SENDER_EMAIL]


